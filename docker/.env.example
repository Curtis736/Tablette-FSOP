## SEDI Tablette - docker/.env.example
## Copie ce fichier en `docker/.env` (ce fichier est ignoré par git).
## Ne commit jamais de secrets.

## Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

## Backend DB (SEDI_APP_INDEPENDANTE)
DB_DATABASE=SEDI_APP_INDEPENDANTE
DB_USER=QUALITE
DB_PASSWORD=QUALITE
DB_ENCRYPT=false
DB_TRUST_CERT=true

## ERP DB (SEDI_ERP)
DB_ERP_SERVER=SERVEURERP
DB_ERP_DATABASE=SEDI_ERP
DB_ERP_USER=QUALITE
DB_ERP_PASSWORD=QUALITE
DB_ERP_ENCRYPT=false
DB_ERP_TRUST_CERT=true

## Secrets (change en prod)
JWT_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME

## Factorial
ENABLE_FACTORIAL_AUTOCLOSE=true
FACTORIAL_API_BASE_URL=https://api.factorialhr.com
FACTORIAL_API_TOKEN=
FACTORIAL_OPEN_SHIFTS_PATH=/api/2026-01-01/resources/attendance/open_shifts
FACTORIAL_SHIFTS_PATH=/api/2026-01-01/resources/attendance/shifts
FACTORIAL_SHIFTS_LOOKBACK_DAYS=2
FACTORIAL_RAW_PAYLOAD_RETENTION_DAYS=30
FACTORIAL_API_TIMEOUT_MS=10000
FACTORIAL_CHECK_START_HOUR=17
FACTORIAL_CHECK_INTERVAL_MINUTES=30

## Grafana
GRAFANA_ADMIN_USER=grafana-admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
GRAFANA_SECRET_KEY=CHANGE_ME
GRAFANA_ROOT_URL=http://127.0.0.1:3002/

## Mounts
SERVICES_HOST_PATH=/mnt/partage_fsop
SERVICES_CONTAINER_PATH=/mnt/services
TEMPLATES_HOST_PATH=/mnt/templates
TEMPLATES_CONTAINER_PATH=/mnt/templates

