ENABLE_FACTORIAL_AUTOCLOSE=true
FACTORIAL_API_BASE_URL=https://api.factorialhr.com
FACTORIAL_API_TOKEN=replace_with_factorial_api_token

# Template supports:
# - {operatorId}: operator identifier (same as tablet operator code)
# - {date}: local date key YYYY-MM-DD
FACTORIAL_STATUS_ENDPOINT_TEMPLATE=/employees/{operatorId}/attendance?date={date}

# Polling IN/OUT architecture (recommended long-term)
# open_shifts: récupère au moins les clock_in (shift ouverts)
FACTORIAL_OPEN_SHIFTS_PATH=/resources/attendance/open_shifts
# shifts: récupère clock_in + clock_out sur une fenêtre (lookback)
FACTORIAL_SHIFTS_PATH=/resources/attendance/shifts

# Paramètre Factorial pour filtrer par employés (numériques)
FACTORIAL_OPEN_SHIFTS_EMPLOYEE_IDS_PARAM=employee_ids
FACTORIAL_SHIFTS_EMPLOYEE_IDS_PARAM=employee_ids

# Paramètres de date sur /resources/attendance/shifts (à adapter si besoin)
FACTORIAL_SHIFTS_FROM_PARAM=start_at
FACTORIAL_SHIFTS_TO_PARAM=end_at

# Fenêtre de recherche pour retrouver les clock_out (ex: 2 jours)
FACTORIAL_SHIFTS_LOOKBACK_DAYS=2

# Rétention des payloads bruts en jours (pour debug/audit)
FACTORIAL_RAW_PAYLOAD_RETENTION_DAYS=30

# Polling window/config
FACTORIAL_CHECK_START_HOUR=17
FACTORIAL_CHECK_INTERVAL_MINUTES=30
FACTORIAL_API_TIMEOUT_MS=10000

## SILOG EDI_JOB
# scheduled = la tâche planifiée sur SVC_SILOG déclenche SEDI_ETDIFF (recommandé)
# ssh = le backend déclenche SILOG.exe via SSH
# (vide) = le backend déclenche SILOG.exe localement (Windows uniquement)
SILOG_REMOTE_MODE=scheduled

## Validation automatique des temps (StatutTraitement NULL → 'O')
# Les temps de la veille (et avant) avec ProductiveDuration > 0 sont validés automatiquement.
# Cela les rend visibles dans V_REMONTE_TEMPS pour SILOG.
ENABLE_AUTO_VALIDATE_TEMPS=true
AUTO_VALIDATE_TEMPS_HOUR=20

## Watchdog pipeline SILOG
# Seuil en heures : si des enregistrements 'O' ne passent pas 'T' après ce délai,
# l'endpoint /api/admin/silog-pipeline-status signale un WARNING.
SILOG_STALE_THRESHOLD_HOURS=24
