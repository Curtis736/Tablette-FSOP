# Maintenance quotidienne - Nettoyage des données incohérentes
0 2 * * * docker exec sedi-tablette-backend node scripts/maintenance.js cleanup >> /var/log/sedi-maintenance.log 2>&1

# Rapport de santé hebdomadaire
0 8 * * 1 docker exec sedi-tablette-backend node scripts/maintenance.js report >> /var/log/sedi-health.log 2>&1

# Validation de l'intégrité des données toutes les 6 heures
0 */6 * * * docker exec sedi-tablette-backend node scripts/maintenance.js validate >> /var/log/sedi-validation.log 2>&1

# Vérification FSOP templates toutes les 5 minutes
*/5 * * * * cd /home/Tablette-FSOP && docker exec sedi-tablette-backend sh -lc 'test -d "/mnt/templates/Qualite/4_Public/A disposition/DOSSIER SMI/Formulaires" && test -f "/mnt/templates/Qualite/4_Public/A disposition/DOSSIER SMI/Formulaires/Liste des formulaires.xlsx"' || echo "$(date -Iseconds) FSOP_TEMPLATES_MISSING" >> /var/log/fsop-health.log

# Watchdog proactif (DB + templates + pipeline SILOG)
*/10 * * * * cd /home/Tablette-FSOP && docker exec sedi-tablette-backend node scripts/proactive-watchdog.js >> /var/log/sedi-watchdog.log 2>&1 || echo "$(date -Iseconds) WATCHDOG_WARNING (db/templates/silog pipeline)" >> /var/log/sedi-watchdog-alert.log

# Nettoyage des logs anciens (plus de 30 jours)
0 3 * * * find /var/log/sedi-*.log -mtime +30 -delete

# IMPORTANT PROD
# - NE PAS planifier EDI_JOB/SEDI_ETDIFF ici (Linux).
# - Le déclenchement SILOG est géré sur Windows (poste SVC_SILOG / utilisateur Production8).
# - En exploitation, éviter tout déclenchement "toutes les minutes".
#   Si une tâche périodique SILOG est nécessaire côté Windows, cible recommandée: toutes les 15 minutes.


























